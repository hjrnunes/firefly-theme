        "storage.control.clojure",
      ],
      "settings": {
        "foreground": "#42CEF3",
      }
    },
    {
      "name": "Clojure constant",
      "scope": [
        "constant.language.nil.clojure",
        "constant.language.boolean.clojure"
      ],
      "settings": {
        "foreground": "#FFB615",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Clojure function name",
      "scope": [
        "entity.name.function.clojure",
      ],
      "settings": {
        "foreground": "#42CEF3"
      }
    },
    {
      "name": "Clojure ns alias",
