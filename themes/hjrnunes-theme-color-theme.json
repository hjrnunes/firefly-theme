        "source.groovy keyword"
      ],
      "settings": {
        "foreground": "#b5f135",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Properties key",
      "scope": [
        "keyword.other.properties",
        "source.ini entity.name.section",
        "meta.key-value keyword"
      ],
      "settings": {
        "foreground": "#0099ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Properties value",
      "scope": [
        "meta.key-value string",
        "source.ini string"
      ],
      "settings": {
        "foreground": "#3adf3a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "TODO / FIXME",
      "scope": [
        "comment meta.annotation.todo",
        "comment keyword.codetag.notation",
        "keyword.codetag.notation"
      ],
      "settings": {
        "foreground": "#ffff00",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#c9c9c2"
      }
    },
    {
      "name": "Invalid / bad character",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#c9c9c2",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Clojure keyword",
      "scope": [
        "constant.keyword.clojure",
      ],
      "settings": {
        "foreground": "#CDF820FF",
      }
    },
    {
      "name": "Clojure core",
