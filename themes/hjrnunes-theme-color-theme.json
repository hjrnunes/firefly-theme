{
  "name": "Firefly",
  "type": "dark",
  "colors": {
    "editor.background": "#2e3436",
    "editor.foreground": "#c9c9c2",
    "editorCursor.foreground": "#ff3300",
    "editor.lineHighlightBackground": "#3e454880",
    "editor.selectionBackground": "#00000099",
    "editor.selectionHighlightBackground": "#7287a540",
    "editorLineNumber.foreground": "#bbcdd1",
    "editorLineNumber.activeForeground": "#ffffff",
    "editorGutter.background": "#2e3436",
    "editorIndentGuide.background1": "#414040",
    "editorIndentGuide.activeBackground1": "#696969",
    "editorWhitespace.foreground": "#696969",
    "editorRuler.foreground": "#0d1622",
    "editor.findMatchBackground": "#d3ff0d40",
    "editor.findMatchHighlightBackground": "#d3ff0d25",
    "editor.wordHighlightBackground": "#1f6e1640",
    "editor.wordHighlightStrongBackground": "#1f6e1660",
    "editorBracketMatch.background": "#c0c0c020",
    "editorBracketMatch.border": "#c0c0c0",
    "editorError.foreground": "#ff0000",
    "editorWarning.foreground": "#ffff00",
    "editorInfo.foreground": "#cccccc",
    "editorHint.foreground": "#cccccc",
    "editorOverviewRuler.errorForeground": "#ff0000",
    "editorOverviewRuler.warningForeground": "#ebc700",
    "editorOverviewRuler.infoForeground": "#cccccc",
    "editorOverviewRuler.modifiedForeground": "#808080",
    "editorOverviewRuler.addedForeground": "#008000",
    "editorOverviewRuler.deletedForeground": "#747474",
    "diffEditor.insertedTextBackground": "#16471620",
    "diffEditor.removedTextBackground": "#66666630",
    "diffEditor.insertedLineBackground": "#16471630",
    "diffEditor.removedLineBackground": "#66666620",
    "activityBar.background": "#2e3436",
    "activityBar.foreground": "#c9c9c2",
    "sideBar.background": "#252a2c",
    "sideBar.foreground": "#c9c9c2",
    "sideBarTitle.foreground": "#bbcdd1",
    "statusBar.background": "#1e2527",
    "statusBar.foreground": "#bbcdd1",
    "titleBar.activeBackground": "#2e3436",
    "titleBar.activeForeground": "#c9c9c2",
    "tab.activeBackground": "#2e3436",
    "tab.activeForeground": "#ffffff",
    "tab.inactiveBackground": "#252a2c",
    "tab.inactiveForeground": "#bbcdd1",
    "tab.activeBorderTop": "#1e96e8",
    "editorGroupHeader.tabsBackground": "#252a2c",
    "panel.background": "#2e3436",
    "panelTitle.activeForeground": "#c9c9c2",
    "terminal.background": "#2e3436",
    "terminal.foreground": "#f5f1fa",
    "terminal.ansiBlue": "#3e91ea",
    "terminal.ansiRed": "#ef0000",
    "terminal.ansiBrightBlue": "#3e91ea",
    "terminal.ansiBrightRed": "#ef0000",
    "gitDecoration.modifiedResourceForeground": "#1e96e8",
    "gitDecoration.untrackedResourceForeground": "#6cff1a",
    "input.background": "#252a2c",
    "input.foreground": "#c9c9c2",
    "dropdown.background": "#252a2c",
    "dropdown.foreground": "#c9c9c2",
    "list.activeSelectionBackground": "#3e4548",
    "list.activeSelectionForeground": "#ffffff",
    "list.hoverBackground": "#3e454840",
    "list.highlightForeground": "#6cff1a",
    "scrollbarSlider.background": "#696969aa",
    "scrollbarSlider.hoverBackground": "#696969cc",
    "focusBorder": "#0099ff",
    "button.background": "#0099ff",
    "button.foreground": "#ffffff"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function.definition": "#ffffff",
    "function": "#FFB615",
    "function.defaultLibrary": "#42CEF3",
    "macro.defaultLibrary": "#42CEF3",
    "keyword": { "foreground": "#CDF820", "fontStyle": "" },
    "type": "#FFB615",
    "event": "#FFB615"
  },
  "tokenColors": [
    {
      "name": "Plain text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#c9c9c2"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#a6a684",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc comment",
      "scope": [
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#629755",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#9bb3eb"
      }
    },
    {
      "name": "String escape",
      "scope": [
        "constant.character.escape",
        "string.regexp.character-class"
      ],
      "settings": {
        "foreground": "#cdf820",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal"
      ],
      "settings": {
        "foreground": "#4d98d1"
      }
    },
    {
      "name": "Boolean / null / language constants",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#66cc00",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "variable.other.constant",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#66cc00",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.instanceof",
        "keyword.operator.in",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#faa00f",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator keyword",
      "scope": [
        "keyword.operator",
        "keyword.operator.comparison",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.bitwise"
      ],
      "settings": {
        "foreground": "#c9c9c2"
      }
    },
    {
      "name": "Annotation / Decorator",
      "scope": [
        "entity.name.tag.decorator",
        "meta.decorator punctuation.decorator",
        "storage.type.annotation",
        "punctuation.definition.annotation"
      ],
      "settings": {
        "foreground": "#0099ff"
      }
    },
    {
      "name": "Function / method name (declaration)",
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call entity.name.function",
        "meta.function-call.generic entity.name.function"
      ],
      "settings": {
        "foreground": "#8aa6c1"
      }
    },
    {
      "name": "Built-in functions / support",
      "scope": [
        "support.function",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#33a8ea"
      }
    },
    {
      "name": "Class name",
      "scope": [
        "entity.name.class",
        "entity.name.type.class"
      ],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "name": "Inherited class / interface",
      "scope": [
        "entity.other.inherited-class",
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#0099ff"
      }
    },
    {
      "name": "Abstract class",
      "scope": [
        "entity.name.type.class.abstract"
      ],
      "settings": {
        "foreground": "#ffc66d"
      }
    },
    {
      "name": "Type parameter / generic",
      "scope": [
        "entity.name.type.parameter",
        "storage.type.generic"
      ],
      "settings": {
        "foreground": "#20999d"
      }
    },
    {
      "name": "Support type / class",
      "scope": [
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#b9daf3"
      }
    },
    {
      "name": "Function parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#8aa6c1"
      }
    },
    {
      "name": "Instance field / property",
      "scope": [
        "variable.other.member",
        "variable.other.field",
        "variable.other.property",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#ffcc33",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Static field",
      "scope": [
        "variable.other.static",
        "variable.other.static.property"
      ],
      "settings": {
        "foreground": "#ff9900",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "HTML / XML tag name",
      "scope": [
        "entity.name.tag",
        "meta.tag entity.name.tag"
